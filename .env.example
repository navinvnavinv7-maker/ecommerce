MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecommerce
JWT_SECRET=your_secure_random_string
JWT_REFRESH_SECRET=your_secure_refresh_random_string
PORT=3000
NODE_ENV=development

# Authentication & Security
ADMIN_EMAILS=owner@gmail.com,admin@nexus.io

# SMTP Config (Falls back to console logs in development if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Nexus Couture Support" <support@nexus.io>

# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cloudinary Config (Falls back to local disk storage uploads if blank)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret